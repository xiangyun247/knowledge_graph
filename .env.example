# ============================================================
# 云服务器部署环境变量配置
# ============================================================
#
# 使用方法：
#   1. 复制此文件：cp .env.example .env
#   2. 修改下方所有 [必填] 项
#   3. 不要把填好密码的 .env 文件提交到 Git！
#
# 安全提示：
#   - 所有密码必须修改默认值！
#   - JWT_SECRET 必须是随机字符串（至少32字符）
#   - API Key 填真实的 DeepSeek / 智谱 Key
#   - .env 已在 .dockerignore 中，不会被打包进镜像
# ============================================================

# ==================== 数据库密码（必须修改！） ====================

# Neo4j 密码
NEO4J_PASSWORD=your_neo4j_password_here

# MySQL root 密码
MYSQL_ROOT_PASSWORD=your_mysql_root_password_here

# MySQL 应用用户密码
MYSQL_PASSWORD=your_mysql_app_password_here

# ==================== LLM / AI 服务（必须填写真实 Key） ====================

# DeepSeek API（Agent 对话、知识图谱构建）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 智谱 AI（可选，备用 LLM）
ZHIPU_API_KEY=

# ==================== JWT 认证（安全关键！必须改） ====================

# JWT 签名密钥 — 用这个命令生成随机值：
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-to-a-random-string-at-least-32-characters-long

# ==================== CORS 配置 ====================

# 允许的前端来源（生产环境填实际域名/IP）
# 本地开发用：http://localhost:8080
# 云部署用：http://你的公网IP 或域名
CORS_ORIGINS=*

# ==================== 应用配置 ====================

# 调试模式（生产环境必须是 False！）
DEBUG=False

# 运行环境：development / production
ENVIRONMENT=production

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ==================== Embedding 模型配置 ====================

# 是否使用本地 Embedding 模型（True=本地 bge-large-zh ~2GB内存 / False=远程API省内存）
USE_LOCAL_EMBEDDING=True
LOCAL_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DIM=1024

# 如果 USE_LOCAL_EMBEDDING=False，需要配置远程 Embedding API（OpenAI 兼容格式）
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# ==================== ChromaDB 向量数据库 ====================
CHROMA_PERSIST_DIR=/app/data/chroma_v2
CHROMA_TELEMETRY_ENABLED=false

# ==================== 前端构建上下文（通常不需要改） ====================

# 前端项目路径（相对于后端项目根目录的上级目录）
FRONTEND_CONTEXT=../vue_test_style
