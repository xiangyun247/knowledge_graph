# ==================== Docker Compose 用（复制为 .env，docker-compose 会读取） ====================
# 生产环境务必修改以下密码，且不要将 .env 提交到仓库。

# Neo4j（容器内与 backend/celery 连接用）
NEO4J_PASSWORD=your-neo4j-password-here

# MySQL root 与业务账号
MYSQL_ROOT_PASSWORD=your-mysql-root-password-here
MYSQL_USER=kg_user
MYSQL_PASSWORD=your-mysql-kg-password-here

# ==================== 多 LLM 支持（问答界面可切换模型） ====================
# 在 .env 中配置要使用的模型 API Key；未配置的模型仍会出现在下拉选项中，但选择后会提示「未配置该模型」。

# DeepSeek（Agent/问答默认）
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 通义千问（阿里云 DashScope，OpenAI 兼容接口）
# DASHSCOPE_API_KEY=your-dashscope-api-key-here

# 豆包（火山引擎 Ark，需在控制台创建推理接入点获取 endpoint_id）
# ARK_API_KEY=your-ark-api-key-here
# ARK_MODEL=ep-xxx  # 替换为实际 endpoint_id

# OpenAI GPT-4o / GPT-4 Turbo
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com  # 可选，默认同上

# Google Gemini（官方 OpenAI 兼容接口）
# GEMINI_API_KEY=your-gemini-api-key-here

# xAI Grok
# XAI_API_KEY=your-xai-api-key-here

# 智谱 GLM（OpenAI 兼容）
# ZHIPU_API_KEY=your-zhipu-api-key-here

# 文心一言（需使用 OpenAI 兼容代理或 one-api 等时配置）
# WENXIN_API_KEY=xxx
# WENXIN_BASE_URL=https://your-proxy/v1
# WENXIN_MODEL=completions_pro  # 可选

# Kimi 月之暗面 Moonshot
# MOONSHOT_API_KEY=your-moonshot-api-key-here

# 应用运行环境（可选）
DEBUG=False
ENVIRONMENT=production
LOG_LEVEL=INFO

# ==================== 本地开发用（非 Docker 时 run.py 等会读取） ====================
# HOST=0.0.0.0
# PORT=5001
# NEO4J_URI=bolt://localhost:7687
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_DATABASE=knowledge_graph_system
# REDIS_HOST=localhost
# REDIS_PORT=6379
